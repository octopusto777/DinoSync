/* pages/profile/profile.wxss */

.profile-page {
  background: linear-gradient(180deg, #173126 0%, #11241b 60%, #0f2018 100%);
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ══ 顶部头像区（无磨砂，直接透明融入背景） ══ */
.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 84rpx 32rpx 36rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.10);
  border: 1.5rpx solid rgba(255, 255, 255, 0.20);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-emoji { font-size: 52rpx; }
.user-info { flex: 1; }

.user-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #eef5ef;
  letter-spacing: -0.01em;
}

.member-badge {
  font-size: 20rpx;
  color: #c8f060;
  background: rgba(200, 240, 96, 0.12);
  border: 1rpx solid rgba(200, 240, 96, 0.30);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.streak-row { display: flex; align-items: center; gap: 8rpx; }
.streak-emoji { font-size: 24rpx; }
.streak-text { font-size: 22rpx; color: #7a9983; }
.streak-num { color: #f0a840; font-weight: 600; }

/* ══ 统计四格（轻量，无 blur） ══ */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 0;
  margin: 0 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  overflow: hidden;
}

.stat-card {
  padding: 26rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-card + .stat-card {
  border-left: 1rpx solid rgba(255, 255, 255, 0.10);
}

.stat-num {
  font-size: 34rpx;
  font-weight: 600;
  color: #f0f8f2;
  letter-spacing: -0.02em;
}

.stat-label {
  font-size: 17rpx;
  color: #5d7a63;
  text-align: center;
  line-height: 1.3;
}

/* ══ 成就快报 chips ══ */
.insight-row {
  display: flex;
  gap: 10rpx;
  padding: 0 24rpx 28rpx;
}

.insight-chip {
  flex: 1;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  text-align: center;
}

.insight-chip text {
  color: #7a9983;
  font-size: 20rpx;
}

/* ══ 会员卡（保留玻璃感，主 CTA） ══ */
.member-section { padding: 0 24rpx 28rpx; }

.member-card {
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: rgba(255, 255, 255, 0.10);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.member-card.is-member {
  border-color: rgba(200, 240, 96, 0.28);
  background: rgba(200, 240, 96, 0.06);
}

.member-card-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 90% 120% at 0% 50%, rgba(200, 240, 96, 0.07), transparent);
  pointer-events: none;
}

.member-card-inner {
  position: relative; z-index: 1;
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mc-left { display: flex; align-items: center; gap: 18rpx; }
.mc-icon { font-size: 40rpx; }

.mc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8ede9;
  display: block;
  margin-bottom: 3rpx;
}

.mc-sub { font-size: 20rpx; color: #5d7a63; display: block; }
.mc-right { display: flex; align-items: center; gap: 10rpx; }
.mc-price-wrap { display: flex; align-items: baseline; gap: 2rpx; }
.mc-price { font-size: 34rpx; font-weight: 600; color: #c8f060; }
.mc-price-unit { font-size: 19rpx; color: #5d7a63; }
.mc-active-badge {
  font-size: 19rpx; color: #c8f060;
  background: rgba(200, 240, 96, 0.10);
  border: 1rpx solid rgba(200, 240, 96, 0.28);
  padding: 4rpx 14rpx; border-radius: 999rpx;
}
.mc-arrow { font-size: 30rpx; color: #4f5e51; }

/* ══ 成就墙（单层玻璃，不叠加） ══ */
.achievement-section { padding: 0 24rpx 28rpx; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d6ede0;
}

.section-count {
  font-size: 20rpx;
  color: #4f6255;
  letter-spacing: 0.05em;
}

.achievement-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10rpx;
}

.ach-card {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 18rpx;
  padding: 18rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7rpx;
  text-align: center;
  position: relative;
}

.ach-card.locked { opacity: 0.38; }

.ach-icon-wrap {
  width: 64rpx; height: 64rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  display: flex; align-items: center; justify-content: center;
}

.ach-glow {
  background: rgba(200, 240, 96, 0.10) !important;
}

.ach-icon { font-size: 34rpx; }
.ach-name { font-size: 20rpx; font-weight: 500; color: #d6ede0; line-height: 1.3; }
.ach-desc { font-size: 16rpx; color: #4f6255; line-height: 1.4; }

.ach-check {
  position: absolute;
  top: 10rpx; right: 12rpx;
  font-size: 16rpx;
  color: #c8f060;
}

/* ══ 排行（轻量列表，无 blur） ══ */
.rank-section { padding: 0 24rpx 28rpx; }

.rank-card {
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  overflow: hidden;
}

.rank-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 18rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.rank-row:last-child { border-bottom: none; }
.rank-name { color: #7a9983; font-size: 22rpx; }
.rank-score { color: #c8f060; font-size: 23rpx; font-weight: 600; }

/* ══ 快捷操作（纯列表，无 glass） ══ */
.quick-section { padding: 0 24rpx 20rpx; }

.quick-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 4rpx;
}

.quick-icon { font-size: 38rpx; }
.quick-info { flex: 1; }

.quick-title {
  font-size: 27rpx;
  font-weight: 500;
  color: #d6ede0;
  display: block;
  margin-bottom: 3rpx;
}

.quick-sub { font-size: 21rpx; color: #4f6255; display: block; }
.quick-arrow { font-size: 32rpx; color: #3f5245; }

.divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.07);
  margin: 0;
}

/* ══ 底部 ══ */
.footer-note {
  padding: 36rpx 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-top: 8rpx;
}

.footer-note text {
  font-size: 17rpx;
  color: #2e3a30;
  letter-spacing: 0.06em;
}

.footer-brand {
  font-size: 28rpx;
  color: rgba(200, 240, 96, 0.25);
  letter-spacing: 0.14em;
}
