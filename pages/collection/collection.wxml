<!-- pages/collection/collection.wxml — 数字标本图鉴 -->
<view class="collection-page">

  <!-- ── 顶部标题栏 ── -->
  <view class="col-nav">
    <view class="col-title-wrap">
      <text class="col-title game-font">FOSSIL DEX</text>
      <text class="col-sub">数字标本图鉴</text>
    </view>
    <view class="col-progress-wrap">
      <view class="col-progress-ring">
        <text class="col-progress-num">{{ unlockedCount }}</text>
        <text class="col-progress-slash">/</text>
        <text class="col-progress-total">{{ totalCount }}</text>
      </view>
      <text class="col-progress-label">已解锁</text>
    </view>
  </view>

  <!-- ── 进度条 ── -->
  <view class="global-progress">
    <view class="gp-track">
      <view
        class="gp-fill"
        style="width: {{ progressPct }}%;"
      ></view>
    </view>
    <text class="gp-pct mono">{{ progressPct }}% 完成</text>
  </view>

  <!-- ── 筛选器 ── -->
  <view class="filter-row">
    <view
      class="filter-tab {{ activeFilter === 'all' ? 'active' : '' }}"
      data-filter="all"
      bind:tap="onFilterTap"
    >全部 {{ totalCount }}</view>
    <view
      class="filter-tab {{ activeFilter === 'unlocked' ? 'active active-lime' : '' }}"
      data-filter="unlocked"
      bind:tap="onFilterTap"
    >已解锁 {{ unlockedCount }}</view>
    <view
      class="filter-tab {{ activeFilter === 'locked' ? 'active active-muted' : '' }}"
      data-filter="locked"
      bind:tap="onFilterTap"
    >待解锁 {{ lockedCount }}</view>
  </view>

  <!-- ── 标本网格 ── -->
  <view class="specimen-grid">
    <view
      wx:for="{{ displaySpecimens }}"
      wx:key="id"
      class="spec-cell {{ item.unlocked ? 'unlocked' : 'locked' }}"
      data-id="{{ item.id }}"
      bind:tap="onSpecimenTap"
    >
      <!-- 稀有度顶部条 -->
      <view class="rarity-bar rarity-bar-{{ item.rarity }}"></view>

      <!-- 主内容 -->
      <view class="spec-inner">
        <view class="spec-emoji-wrap">
          <text class="spec-emoji">{{ item.unlocked ? item.emoji : '🔒' }}</text>
        </view>

        <text class="spec-name">{{ item.unlocked ? item.name : '???' }}</text>

        <view class="spec-meta-row">
          <view class="spec-rarity rarity-{{ item.rarity }}">
            <text>{{ item.rarityLabel }}</text>
          </view>
          <view wx:if="{{ item.unlocked }}" class="spec-unlocked-dot"></view>
        </view>

        <text
          wx:if="{{ item.unlocked }}"
          class="spec-era"
        >{{ item.era }}</text>
        <text
          wx:else
          class="spec-locked-hint"
        >{{ item.location }}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{ isEmpty }}" class="empty-state">
    <text class="empty-icon">🦕</text>
    <text class="empty-text">暂无标本</text>
    <button class="empty-btn" bind:tap="goMap">前往地图探索</button>
  </view>

  <view style="height: 40rpx;"></view>
</view>

<!-- ── 标本详情弹窗 ── -->
<view class="detail-mask {{ showDetail ? 'visible' : '' }}" bind:tap="closeDetail"></view>
<view class="detail-panel {{ showDetail ? 'visible' : '' }}">
  <view wx:if="{{ selectedSpec }}">
    <view class="drag-bar"></view>

    <!-- 顶部 -->
    <view class="detail-top" style="background: {{ selectedSpec.accentColor }}10; border-color: {{ selectedSpec.accentColor }}20;">
      <text class="detail-emoji">{{ selectedSpec.emoji }}</text>
      <view class="detail-rarity rarity-{{ selectedSpec.rarity }}">
        <text>{{ selectedSpec.rarityLabel }}</text>
      </view>
    </view>

    <!-- 名称 -->
    <view class="detail-names">
      <text class="detail-name">{{ selectedSpec.name }}</text>
      <text class="detail-latin mono">{{ selectedSpec.latinName }}</text>
    </view>

    <!-- 分类信息网格 -->
    <view class="detail-info-grid">
      <view class="info-cell">
        <text class="info-label mono">地质年代</text>
        <text class="info-val">{{ selectedSpec.era }}</text>
      </view>
      <view class="info-cell">
        <text class="info-label mono">距今时间</text>
        <text class="info-val">{{ selectedSpec.period }}</text>
      </view>
      <view class="info-cell">
        <text class="info-label mono">分类</text>
        <text class="info-val">{{ selectedSpec.type }}</text>
      </view>
      <view class="info-cell">
        <text class="info-label mono">发现地</text>
        <text class="info-val">{{ selectedSpec.location }}</text>
      </view>
    </view>

    <!-- 描述 -->
    <view class="detail-desc-wrap">
      <text class="detail-desc">{{ selectedSpec.description }}</text>
    </view>

    <!-- 趣味知识 -->
    <view class="fun-fact-card">
      <text class="fun-label mono">💡 有趣的事</text>
      <text class="fun-text">{{ selectedSpec.funFact }}</text>
    </view>

    <!-- 发现地 -->
    <view class="museum-row">
      <text class="museum-icon">🏛️</text>
      <view>
        <text class="museum-label mono">标本所在地</text>
        <text class="museum-name">{{ selectedSpec.museumName }}</text>
      </view>
    </view>

    <button class="close-detail-btn" bind:tap="closeDetail">关闭</button>
  </view>
</view>

<custom-tab-bar></custom-tab-bar>
