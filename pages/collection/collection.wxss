/* pages/collection/collection.wxss */

.collection-page {
  background: linear-gradient(180deg, #173126 0%, #11241b 58%, #0f2018 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ── 顶部导航 ── */
.col-nav {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 80rpx 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.12);
}

.col-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #eef5ef;
  display: block;
  letter-spacing: -0.02em;
  margin-bottom: 4rpx;
}

.col-sub {
  font-size: 18rpx;
  color: #6f8d79;
  letter-spacing: 0.15em;
  font-family: 'Courier New', monospace;
}

.col-progress-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.col-progress-ring {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.col-progress-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #c8f060;
  font-family: 'Courier New', monospace;
}

.col-progress-slash {
  font-size: 24rpx;
  color: #6f8d79;
}

.col-progress-total {
  font-size: 28rpx;
  color: #6f8d79;
  font-family: 'Courier New', monospace;
}

.col-progress-label {
  font-size: 18rpx;
  color: #6f8d79;
}

/* ── 全局进度条 ── */
.global-progress {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.gp-track {
  flex: 1;
  height: 4rpx;
  background: #355846;
  border-radius: 100rpx;
  overflow: hidden;
}

.gp-fill {
  height: 100%;
  background: #c8f060;
  border-radius: 100rpx;
  transition: width 0.6s ease;
}

.gp-pct {
  font-size: 20rpx;
  color: #6f8d79;
  white-space: nowrap;
  letter-spacing: 0.05em;
}

/* ── 筛选标签 ── */
.filter-row {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.filter-tab {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #7f9a87;
  padding: 12rpx 8rpx;
  border-radius: 12rpx;
  border: 1rpx solid transparent;
  transition: all 0.2s;
}

.filter-tab.active {
  background: rgba(200, 240, 96, 0.1);
  border-color: rgba(200, 240, 96, 0.3);
  color: #c8f060;
}

.filter-tab.active-muted {
  background: rgba(255, 255, 255, 0.04) !important;
  border-color: #252b26 !important;
  color: #8a9b8c !important;
}

/* ── 标本网格 ── */
.specimen-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 24rpx;
}

.spec-cell {
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  transition: all 0.2s;
}

.spec-cell.locked {
  opacity: 0.6;
}

.spec-cell.unlocked {
  border-color: rgba(255, 255, 255, 0.32);
}

/* 稀有度顶部色条 */
.rarity-bar {
  height: 3rpx;
  width: 100%;
}

.rarity-bar-common { background: linear-gradient(90deg, #c8f060, transparent); }
.rarity-bar-rare { background: linear-gradient(90deg, #f0a840, transparent); }
.rarity-bar-legendary { background: linear-gradient(90deg, #a880f0, transparent); }

.spec-inner {
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.spec-emoji-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.spec-emoji {
  font-size: 44rpx;
}

.spec-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8ede9;
  letter-spacing: -0.01em;
}

.spec-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.spec-rarity {
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
}

.rarity-common { background: rgba(200,240,96,0.1); color: #c8f060; border: 1rpx solid rgba(200,240,96,0.25); }
.rarity-rare { background: rgba(240,168,64,0.1); color: #f0a840; border: 1rpx solid rgba(240,168,64,0.25); }
.rarity-legendary { background: rgba(168,128,240,0.1); color: #a880f0; border: 1rpx solid rgba(168,128,240,0.25); }

.spec-unlocked-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #c8f060;
}

.spec-era {
  font-size: 20rpx;
  color: #4f5e51;
  font-family: 'Courier New', monospace;
}

.spec-locked-hint {
  font-size: 20rpx;
  color: #4f5e51;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 32rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #4f5e51; }

.empty-btn {
  margin-top: 16rpx;
  background: #c8f060;
  color: #0d0f0e;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  padding: 22rpx 48rpx;
  border: none;
}

/* ── 详情弹窗 ── */
.detail-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0);
  z-index: 200;
  pointer-events: none;
  transition: background 0.3s;
}

.detail-mask.visible {
  background: rgba(0,0,0,0.7);
  pointer-events: auto;
}

.detail-panel {
  position: fixed;
  bottom: -100%; left: 0; right: 0;
  z-index: 201;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.28);
  padding: 16rpx 32rpx 80rpx;
  transition: bottom 0.35s cubic-bezier(0.32, 0, 0.15, 1);
  max-height: 90vh;
  overflow-y: auto;
}

.detail-panel.visible { bottom: 0; }

.drag-bar {
  width: 72rpx; height: 6rpx;
  background: #252b26;
  border-radius: 100rpx;
  margin: 0 auto 28rpx;
}

.detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-radius: 20rpx;
  border: 1rpx solid #252b26;
  margin-bottom: 24rpx;
}

.detail-emoji { font-size: 72rpx; }

.detail-rarity {
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
}

.detail-names {
  margin-bottom: 24rpx;
}

.detail-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #e8ede9;
  display: block;
  letter-spacing: -0.02em;
  margin-bottom: 6rpx;
}

.detail-latin {
  font-size: 22rpx;
  color: #4f5e51;
  letter-spacing: 0.04em;
}

.detail-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.info-cell {
  background: rgba(255, 255, 255, 0.13);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  padding: 20rpx;
}

.info-label {
  font-size: 18rpx;
  color: #4f5e51;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 6rpx;
}

.info-val {
  font-size: 24rpx;
  color: #e8ede9;
  font-weight: 500;
  display: block;
}

.detail-desc-wrap {
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: #8a9b8c;
  line-height: 1.7;
}

.fun-fact-card {
  background: rgba(200, 240, 96, 0.04);
  border: 1rpx solid rgba(200, 240, 96, 0.12);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.fun-label {
  font-size: 18rpx;
  color: #c8f060;
  letter-spacing: 0.08em;
  display: block;
  margin-bottom: 10rpx;
}

.fun-text {
  font-size: 26rpx;
  color: #8a9b8c;
  line-height: 1.6;
}

.museum-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.13);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
}

.museum-icon { font-size: 36rpx; }

.museum-label {
  font-size: 18rpx;
  color: #4f5e51;
  letter-spacing: 0.08em;
  display: block;
  margin-bottom: 4rpx;
}

.museum-name {
  font-size: 26rpx;
  color: #e8ede9;
  font-weight: 500;
}

.close-detail-btn {
  width: 100%;
  background: rgba(255, 255, 255, 0.2);
  color: #f3fff7;
  font-size: 28rpx;
  border: none;
  border-radius: 999rpx;
  padding: 24rpx 0;
}
