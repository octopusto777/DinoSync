.knowledge-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #173126 0%, #11241b 58%, #0f2018 100%);
  padding: 32rpx 24rpx 60rpx;
}

.header {
  margin: 24rpx 0 20rpx;
}

.title {
  color: #eef5ef;
  font-size: 44rpx;
  font-weight: 600;
  display: block;
}

.sub {
  color: #6f8d79;
  font-size: 20rpx;
  margin-top: 8rpx;
  display: block;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.article-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-radius: 20rpx;
  padding: 20rpx;
}

.article-card.locked {
  opacity: 0.5;
}

.article-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.tag {
  color: #c8f060;
  font-size: 20rpx;
}

.mins {
  color: #6f8d79;
  font-size: 20rpx;
}

.article-title {
  color: #eef5ef;
  font-size: 30rpx;
  line-height: 1.35;
  display: block;
}

.article-meta {
  color: #a5b9aa;
  font-size: 22rpx;
  margin-top: 10rpx;
  display: block;
}

.hint {
  margin-top: 18rpx;
}

.hint text {
  color: #7f9a87;
  font-size: 20rpx;
}

.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  opacity: 0;
  pointer-events: none;
  transition: opacity .2s;
}

.detail-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.detail-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  transform: translateY(100%);
  transition: transform .24s;
  background: rgba(255, 255, 255, 0.16);
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(32rpx);
  -webkit-backdrop-filter: blur(32rpx);
  border-radius: 28rpx 28rpx 0 0;
  padding: 20rpx 24rpx 40rpx;
}

.detail-panel.show {
  transform: translateY(0);
}

.drag {
  width: 70rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #2e3630;
  margin: 0 auto 20rpx;
}

.detail-tag {
  color: #c8f060;
  font-size: 20rpx;
}

.detail-title {
  color: #e8ede9;
  font-size: 34rpx;
  font-weight: 600;
  margin-top: 8rpx;
  display: block;
}

.detail-body {
  color: #8a9b8c;
  font-size: 26rpx;
  line-height: 1.7;
  margin-top: 14rpx;
  display: block;
}
